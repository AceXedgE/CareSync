{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    
    "module": "esnext",
    "moduleResolution": "bundler",
    
    "jsx": "react-jsx",
    
    "types": ["vite/client"],

    "noEmit": true,
    "skipLibCheck": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },

  "include": ["src"]
}